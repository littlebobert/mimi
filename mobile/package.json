{
  "name": "mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start --dev-client",
    "start:tunnel": "expo start --dev-client --tunnel --clear",
    "ios:device": "DEVELOPER_DIR=/Applications/Xcode-beta.app/Contents/Developer expo run:ios --device",
    "ios:device:install": "DEVELOPER_DIR=/Applications/Xcode-beta.app/Contents/Developer expo run:ios --device --no-bundler",
    "patch:ios-scene": "node scripts/patch-ios-scene-lifecycle.js && node scripts/patch-expo-dev-launcher-scene.js",
    "postinstall": "node scripts/patch-expo-dev-launcher-scene.js",
    "android:device": "expo run:android --device",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web --output-dir dist-web"
  },
  "dependencies": {
    "@mykin-ai/expo-audio-stream": "^0.3.5",
    "expo": "~54.0.34",
    "expo-asset": "~12.0.13",
    "expo-audio": "~1.1.1",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
